# Copy to .env.local and fill with values from Supabase (Connect dialog or API settings).

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Prefer the publishable key (sb_publishable_…). Legacy anon JWT still works if set instead.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=YOUR_PUBLISHABLE_KEY

# Optional legacy name (used if PUBLISHABLE_KEY is unset):
# NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_JWT